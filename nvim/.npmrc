# Supply-chain hardening: never run package install scripts (postinstall, etc.)
# in this directory. Postinstall scripts are the #1 npm supply-chain attack
# vector. Run `npm ci` here to install pinned versions from package-lock.json.
ignore-scripts=true

# Fail loudly on integrity / signature mismatches.
audit-level=moderate

# Don't auto-update the lockfile during install. Use `npm install <pkg>` only
# when intentionally adding/upgrading a dependency.
package-lock=true
save-exact=true
